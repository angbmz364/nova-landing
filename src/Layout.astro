<style is:global>
  @import 'tailwindcss';

  @theme {
    --color-primary: #0F0F0F;
    --color-secondary: #424242;
  }

  html {
    scrollbar-gutter: stable;
  }

  body {
    font-family: "Geist Sans", sans-serif;
    color: var(--color-primary);
    background: #FAFAFA;
    overflow-x: hidden;
  }
  h3 {
    font-family: "Geist Mono", monospace;
    color: var(--color-secondary);
  }
  .workflowcard-step {
    font-family: "Geist Mono", monospace;

  }

  footer a:hover {
    color: white;
  }

</style>
