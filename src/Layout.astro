  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Nova es un asistente de inteligencia artificial diseñado para ayudarte a resolver tus dudas y apoyar a los docentes con recordatorios de tareas, creación de grupos, exposición de material, y más.">
  <meta name="author" content="SaskDev">
