---
import Card from "./Card.astro";
---

<section class="w-screen mb-10 mt-40" id="features">
  <div
    class="flex flex-col space-y-10 items-start  justify-center w-[90%] mx-auto"
  >
    <div class="flex items-start w-full justify-between">
      <h3 class="text-primary text-lg">
        [02 Caracteristicas]
      </h3>
      <h2
        class="text-secondary text-5xl text-right [&>span]:text-primary font-semibold max-w-[60%]"
      >
        Ofrece más que solo una herramienta - <span>Ofrece control</span>.
      </h2>
    </div>
    <div class="grid grid-cols-3 grid-rows-3 gap-2 w-full auto-rows-[150px]">
      <div class="col-span-2 row-span-2 bg-white rounded-lg p-2 flex flex-col items-center justify-center text-secondary shadow-xs">
        <div class="text-2xl font-bold">Carta 1</div>
        <div class="text-xs text-zinc-400 mt-1">principal</div>
      </div>
      
      <div class="row-span-3 bg-white rounded-lg p-2 flex flex-col items-center justify-center text-secondary shadow-xs">
        <div class="text-2xl font-bold">Carta 2</div>
        <div class="text-xs text-zinc-400 mt-1">vertical</div>
      </div>
      
      <div class="bg-white rounded-lg p-2 flex flex-col items-center justify-center text-secondary shadow-xs">
        <div class="text-lg font-semibold">Carta 4</div>
        <div class="text-xs text-zinc-400 mt-1">abajo</div>
      </div>
      
      <div class="bg-white rounded-lg p-2 flex flex-col items-center justify-center text-secondary shadow-xs">
        <div class="text-lg font-semibold">Carta 3</div>
        <div class="text-xs text-zinc-400 mt-1">centro</div>
      </div>
    </div>
    <div class="w-full space-y-2">
    </div>
  </div>
</section>
